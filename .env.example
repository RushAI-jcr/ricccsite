# PubMed API (optional — increases rate limit from 3/s to 10/s)
# Register free at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# Semantic Scholar API (optional — gives dedicated rate limit)
# Register free at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Vercel Cron secret (required for monthly publication refresh)
# Generate with: openssl rand -base64 32
CRON_SECRET=
