# ── Publication APIs (optional — improve rate limits) ──────────────
# Register free at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
# Register free at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# ── Staff Admin Panel (required for /staff/ to work) ──────────────
# Shared passphrase for lab members (8+ characters)
ADMIN_PASSPHRASE=
# Cookie encryption key — generate with: openssl rand -base64 32
SESSION_SECRET=
# Fine-grained GitHub PAT with Contents read+write on your repo
# Create at: https://github.com/settings/tokens?type=beta
GITHUB_BOT_TOKEN=

# ── Contact Form (required for email delivery) ────────────────────
# Resend transactional email — https://resend.com/
RESEND_API_KEY=
# Must match your verified domain in Resend
RESEND_DOMAIN=riccc-lab.com

# ── Vercel Cron (required for monthly publication refresh) ────────
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ── Public (safe to commit, used for CSRF checks) ────────────────
NEXT_PUBLIC_SITE_URL=https://riccc-lab.com
